# Copy to .env at the repo root for local (no-sandbox) pipeline runs.
# .env is gitignored — NEVER commit real keys.

# --- required ------------------------------------------------------------
HAI_API_KEY=hk-your-key-here
GRADIUM_API_KEY=gd_your-key-here

# --- synthesis backend ----------------------------------------------------
# Local Ollama (default for local dev):
SYNTH_URL=http://127.0.0.1:11434/v1/chat/completions
SYNTH_MODEL=qwen3:latest
# SYNTH_TOKEN not needed for Ollama.
#
# OpenRouter alternative (better runbook quality):
# SYNTH_URL=https://openrouter.ai/api/v1/chat/completions
# SYNTH_TOKEN=sk-or-your-key-here
# SYNTH_MODEL=anthropic/claude-sonnet-4.5

# --- optional tuning -------------------------------------------------------
RUNBOOKS_DIR=./runbooks-out
# HOLO_MODEL=holo3-1-35b-a3b
# HOLO_RPM=10            # raise after adding H credits
# SCENE_THRESH=0.10
# FLOOR_SECS=1
# MAX_WIDTH=1920
# STT_LANGUAGE=en
# ALIGN_SLOP_S=3
